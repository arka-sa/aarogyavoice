QDRANT_URL=https://your-cluster.qdrant.tech
QDRANT_API_KEY=your_qdrant_api_key

# ── LLM Provider: choose "claude" or "gemini" ──────────────────────────────
LLM_PROVIDER=gemini

# Claude (Anthropic) — used when LLM_PROVIDER=claude
ANTHROPIC_API_KEY=your_anthropic_api_key

# Gemini (Google) — used when LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
# Model name — change to whatever Gemini version you have access to
GEMINI_MODEL=gemini-2.5-pro

VAPI_API_KEY=your_vapi_api_key

# Port for your FastAPI server
PORT=8000
